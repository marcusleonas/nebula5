---
import { ArrowLeft, ArrowRight, Dices } from "@lucide/astro";

interface Webring {
    name: string;
    href: string;
    prev: string;
    next: string;
    rand?: string;
}

const webrings: Webring[] = [
    {
        name: "conehead webring",
        href: "https://coneheads.n3bula.lol",
        prev: "https://coneheads.n3bula.lol/redirect.html?to=prev&name=n3bula",
        rand: "https://coneheads.n3bula.lol/redirect.html?to=random&name=n3bula",
        next: "https://coneheads.n3bula.lol/redirect.html?to=next&name=n3bula",
    },
    {
        name: "bucket webring",
        href: "https://webring.bucketfish.me",
        prev: "https://webring.bucketfish.me/redirect.html?to=prev&name=n3bula",
        rand: "https://webring.bucketfish.me/redirect.html?to=next&name=n3bula",
        next: "https://webring.bucketfish.me/redirect.html?to=random&name=n3bula",
    },
    {
        name: "Webmaster Webring",
        href: "https://webmasterwebring.netlify.app",
        prev: "https://webmasterwebring.netlify.app?n3bula-previous",
        rand: "https://webmasterwebring.netlify.app?n3bula-random",
        next: "https://webmasterwebring.netlify.app?n3bula-next",
    },
    {
        name: "no ai webring",
        href: "https://baccyflap.com/noai",
        prev: "https://baccyflap.com/noai/?prv&s=nbl",
        rand: "https://baccyflap.com/noai/?rnd",
        next: "https://baccyflap.com/noai/?nxt&s=nbl",
    },
    {
        name: "yaoi webring",
        href: "https://www.virtuagirl.net/yuriwebring.html",
        prev: "https://www.virtuagirl.net/webring.htm#NBL0",
        next: "https://www.virtuagirl.net/webring.htm#NBL1",
    },
];
---

<div class="webrings">
    {
        webrings.map(({ name, href, prev, next, rand }) => (
            <div class="webring">
                <a href={href} class="webring-name">
                    {name}
                </a>
                <div class="webring-links">
                    <a href={prev} title="Previous">
                        <ArrowLeft size={14} />
                    </a>
                    {rand && (
                        <a href={rand} title="Random">
                            <Dices size={14} />
                        </a>
                    )}
                    <a href={next} title="Next">
                        <ArrowRight size={14} />
                    </a>
                </div>
            </div>
        ))
    }

    <div class="webring external">
        <link
            rel="stylesheet"
            href="https://cdring.neocities.org/cdring/onionring.css"
        />
        <div id="cdr">
            <script
                type="text/javascript"
                src="https://cdring.neocities.org/cdring/onionring-variables.js"
                is:raw></script>
            <script
                type="text/javascript"
                src="https://cdring.neocities.org/cdring/onionring-widget.js"
                is:raw></script>
        </div>
    </div>
    <div class="webring external">
        <script src="https://silly.possiblyaxolotl.com/ring/webstring.js" is:raw
        ></script>
    </div>
</div>
