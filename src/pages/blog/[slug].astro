---
import { getCollection, getEntry, render } from "astro:content";
import Base from "~/layouts/base.astro";

import { NotebookPen } from "@lucide/astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const toc = headings.filter(
  (heading) => heading.depth >= 2 && heading.depth <= 3,
);
---

<Base
  title={entry.data.title}
  description={entry.data.title}
  icon={NotebookPen}
>
  <section class="has-sidebar">
    <aside class="sidebar">
      <div class="sidebar-box sidebar-top-padding">
        <h3>Table of Contents</h3>

        <nav class="toc">
          <ul>
            {
              toc.map((heading) => (
                <li
                  class:list={{
                    "toc-h2": heading.depth === 2,
                    "toc-h3": heading.depth === 3,
                  }}
                >
                  <a href={`#${heading.slug}`}>{heading.text}</a>
                </li>
              ))
            }
            {toc.length === 0 && <p>No headings.</p>}
          </ul>
        </nav>
      </div>
    </aside>
    <div class="content">
      <div>
        <p style="padding:0;">
          <a href="/blog">&lt; Go Back</a> | Date posted: {
            new Date(entry.data.date).toLocaleDateString("en-GB")
          }
        </p>
      </div>
      <hr />
      <Content />
    </div>
  </section>
</Base>
