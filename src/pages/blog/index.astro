---
import Base from "~/layouts/base.astro";
import { BookText } from "@lucide/astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// Get all unique tags
const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<Base
  title="Blog"
  description="Blog posts & rambles I've written"
  icon={BookText}
>
  <section class="blog-page">
    <div class="blog-toolbar">
      <input
        type="text"
        id="search"
        placeholder="Search posts..."
        class="blog-search"
      />

      <div class="tag-filters">
        <button class="tag active" data-tag="all"> All</button>

        {
          tags.map((tag) => (
            <button class="tag" data-tag={tag}>
              #{tag}
            </button>
          ))
        }
      </div>
    </div>

    <div class="posts-grid" id="posts">
      {
        posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="post-card"
            data-tags={post.data.tags.join(",")}
            data-title={`${post.data.title} ${post.data.summary}`.toLowerCase()}
          >
            <div class="post-meta">
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString("en-GB", {
                  day: "numeric",
                  month: "short",
                  year: "numeric",
                })}
              </time>
            </div>

            <h2>{post.data.title}</h2>

            <p>{post.data.summary}</p>

            <div class="post-tags">
              {post.data.tags.map((tag) => (
                <span>#{tag}</span>
              ))}
            </div>
          </a>
        ))
      }
    </div>

    <p class="no-results" id="no-results" hidden>No posts found.</p>
  </section>

  <script>
    const searchInput = document.getElementById("search");
    const tagButtons = document.querySelectorAll(".tag");
    const posts = document.querySelectorAll(".post-card");
    const noResults = document.getElementById("no-results");

    let activeTag = "all";

    function filterPosts() {
      const query = searchInput.value.toLowerCase().trim();

      let visiblePosts = 0;

      posts.forEach((post) => {
        const title = post.dataset.title;
        const tags = post.dataset.tags.split(",");

        const matchesSearch = title.includes(query);
        const matchesTag = activeTag === "all" || tags.includes(activeTag);

        const visible = matchesSearch && matchesTag;

        post.style.display = visible ? "" : "none";

        if (visible) visiblePosts++;
      });

      noResults.hidden = visiblePosts !== 0;
    }

    searchInput.addEventListener("input", filterPosts);

    tagButtons.forEach((button) => {
      button.addEventListener("click", () => {
        activeTag = button.dataset.tag;

        tagButtons.forEach((btn) => btn.classList.remove("active"));

        button.classList.add("active");

        filterPosts();
      });
    });
  </script>
</Base>

<style>
  .blog-page {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .blog-toolbar {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-bottom: 0.25rem;
  }

  .blog-search {
    width: 100%;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid var(--border);
    background: url(/images/noise.png), var(--surface2);
    color: var(--text);
    font: inherit;
    outline: none;
    transition: all 0.2s;
  }

  .blog-search::placeholder {
    color: var(--dim);
  }

  .blog-search:focus {
    border-color: var(--border-hover);
    background: rgba(196, 173, 225, 0.04);
  }

  .tag-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    appearance: none;
  }

  .tag.active {
    background: rgba(196, 173, 225, 0.12);
    border-color: var(--border-hover);
    color: var(--primary);
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
    gap: 0.75rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;

    padding: 1rem;
    border-radius: 0.5rem;
    border: 1px solid var(--border);

    background: url(/images/noise.png), var(--surface);
    text-decoration: none;

    transition: transform 0.2s ease, border-color 0.2s ease,
      background 0.2s ease;
  }

  .post-card:hover {
    transform: translateY(-2px);
    border-color: var(--border-hover);
    background: url(/images/noise.png), rgba(196, 173, 225, 0.03);
    text-decoration: none;
  }

  .post-card h2 {
    font-size: 1.2rem;
    line-height: 1.1;
    color: var(--text);
  }

  .post-card p {
    color: var(--dim);
    line-height: 1.5;
    flex: 1;
  }

  .post-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.85rem;
    color: var(--primary);
    letter-spacing: 0.04em;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .post-tags span {
    padding: 0.3rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface2);
    font-size: 0.8rem;
    color: var(--dim);
  }

  .no-results {
    text-align: center;
    color: var(--dim);
    padding: 1rem 0;
  }

  @media (max-width: 640px) {
    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
